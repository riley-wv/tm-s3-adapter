# Host port mappings. The compose file binds these to 127.0.0.1 on the VPS.
# Expose externally through Cloudflare Tunnel hostnames, not direct public ports.
NODE_ENV=production
VPS_ADMIN_DASHBOARD_PORT=8787
VPS_ADMIN_API_PORT=8788
VPS_SMB_PORT=1445
# SMB URL port shown in dashboard/API.
# For direct local Docker use this usually matches VPS_SMB_PORT.
# For production with tunnel + local client TCP forward, clients typically use localhost:<forwarded-port>.
VPS_SMB_PUBLIC_PORT=1445
VPS_SFTP_PORT=2222
VPS_DATA_DIR=/data/vps
VPS_SMB_SHARE_ROOT=/data/vps/smb-share
VPS_ADMIN_WEB_ROOT=/app/web/vps-public

# Service auth
VPS_API_TOKEN=replace-with-strong-token
VPS_ADMIN_USERNAME=admin
VPS_ADMIN_PASSWORD=replace-with-strong-admin-password
VPS_ADMIN_SESSION_SECONDS=43200

# SMB manager/runtime
VPS_SAMBA_MANAGE_ENABLED=true
# Stream backend for SMB alternate data streams:
# - xattr (default): best performance, requires xattr support on storage path
# - depot: compatibility mode for mounts/filesystems without xattr support
VPS_SAMBA_STREAMS_BACKEND=xattr
VPS_SAMBA_CONF_DIR=/etc/samba/smb.conf.d/tm-adapter
VPS_SAMBA_MAIN_CONF=/etc/samba/smb.conf
VPS_SAMBA_GENERATED_CONF=/etc/samba/smb.conf.d/tm-adapter/_generated.conf
VPS_SAMBA_INCLUDE_LINE=include = /etc/samba/smb.conf.d/tm-adapter/_generated.conf
VPS_SAMBA_RESTART_CMD=smbcontrol all reload-config || pkill -HUP smbd || true

# Cloud mount manager (rclone)
VPS_MOUNT_MANAGE_ENABLED=true
VPS_MOUNT_POLL_SECONDS=30
VPS_RCLONE_CACHE_DIR=/data/vps/rclone-vfs-cache
VPSD_RCLONE_BINARY=rclone

# SFTP access
VPS_SFTP_USERNAME=tmbackup
VPS_SFTP_PASSWORD=replace-with-strong-sftp-password
VPS_SFTP_UID=10000
VPS_SFTP_GID=10000

# Postgres config store (required for setup/settings config persistence)
VPS_POSTGRES_HOST=postgres
VPS_POSTGRES_PORT=5432
VPS_POSTGRES_DATABASE=tm_adapter
VPS_POSTGRES_USER=tm_adapter
VPS_POSTGRES_PASSWORD=replace-with-strong-postgres-password
VPS_POSTGRES_SSL_MODE=disable

# ----------------------------------------------------------------------
# Optional enterprise dual-source settings (UI + env)
# Precedence:
#   <NAME>_FORCE > UI value > <NAME>_DEFAULT > app default
#
# Leave unset to keep local/default behavior.
# Set *_DEFAULT to provide infrastructure defaults that UI can override.
# Set *_FORCE to lock values so UI cannot change them.
# ----------------------------------------------------------------------

# Enterprise mode and protocol auth modes
# VPS_ENTERPRISE_FEATURES_ENABLED_DEFAULT=false
# VPS_ENTERPRISE_FEATURES_ENABLED_FORCE=false
# VPS_ADMIN_AUTH_MODE_DEFAULT=local
# VPS_ADMIN_AUTH_MODE_FORCE=local
# VPS_SMB_AUTH_MODE_DEFAULT=local
# VPS_SMB_AUTH_MODE_FORCE=local
# VPS_SFTP_AUTH_MODE_DEFAULT=local
# VPS_SFTP_AUTH_MODE_FORCE=local

# Security policy
# VPS_SECURITY_IP_ALLOWLIST_DEFAULT=
# VPS_SECURITY_IP_ALLOWLIST_FORCE=
# VPS_SECURITY_BREAK_GLASS_ENABLED_DEFAULT=true
# VPS_SECURITY_BREAK_GLASS_ENABLED_FORCE=true
# VPS_SECURITY_AUDIT_RETENTION_DAYS_DEFAULT=180
# VPS_SECURITY_AUDIT_RETENTION_DAYS_FORCE=180

# OIDC settings
# VPS_OIDC_ISSUER_DEFAULT=
# VPS_OIDC_ISSUER_FORCE=
# VPS_OIDC_CLIENT_ID_DEFAULT=
# VPS_OIDC_CLIENT_ID_FORCE=
# VPS_OIDC_CLIENT_SECRET_DEFAULT=
# VPS_OIDC_CLIENT_SECRET_FORCE=
# VPS_OIDC_SCOPES_DEFAULT=openid profile email groups
# VPS_OIDC_SCOPES_FORCE=
# VPS_OIDC_ADMIN_GROUP_DEFAULT=
# VPS_OIDC_ADMIN_GROUP_FORCE=
# VPS_OIDC_READONLY_GROUP_DEFAULT=
# VPS_OIDC_READONLY_GROUP_FORCE=

# Directory settings
# VPS_DIRECTORY_DOMAIN_DEFAULT=
# VPS_DIRECTORY_DOMAIN_FORCE=
# VPS_DIRECTORY_REALM_DEFAULT=
# VPS_DIRECTORY_REALM_FORCE=
# VPS_DIRECTORY_URL_DEFAULT=
# VPS_DIRECTORY_URL_FORCE=
# VPS_DIRECTORY_BIND_DN_DEFAULT=
# VPS_DIRECTORY_BIND_DN_FORCE=
# VPS_DIRECTORY_BIND_PASSWORD_DEFAULT=
# VPS_DIRECTORY_BIND_PASSWORD_FORCE=
# VPS_WORKGROUP_MAPPINGS_JSON_DEFAULT=[]
# VPS_WORKGROUP_MAPPINGS_JSON_FORCE=[]

# Mount policy mode: policy_templates | global_defaults | guidelines
# VPS_MOUNT_POLICY_MODE_DEFAULT=policy_templates
# VPS_MOUNT_POLICY_MODE_FORCE=

# Postgres config store (required)
# VPS_POSTGRES_ENABLED_DEFAULT=false
# VPS_POSTGRES_ENABLED_FORCE=
# VPS_POSTGRES_HOST_DEFAULT=postgres
# VPS_POSTGRES_HOST_FORCE=
# VPS_POSTGRES_PORT_DEFAULT=5432
# VPS_POSTGRES_PORT_FORCE=
# VPS_POSTGRES_DATABASE_DEFAULT=tm_adapter
# VPS_POSTGRES_DATABASE_FORCE=
# VPS_POSTGRES_USER_DEFAULT=tm_adapter
# VPS_POSTGRES_USER_FORCE=
# VPS_POSTGRES_PASSWORD_DEFAULT=
# VPS_POSTGRES_PASSWORD_FORCE=
# VPS_POSTGRES_SSL_MODE_DEFAULT=disable
# VPS_POSTGRES_SSL_MODE_FORCE=
