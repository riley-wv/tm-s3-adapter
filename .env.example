# Host port mappings (works for local laptop or VPS)
VPS_ADMIN_DASHBOARD_PORT=8787
VPS_ADMIN_API_PORT=8788
VPS_SMB_PORT=1445
# SMB URL port shown in dashboard/API (usually same as VPS_SMB_PORT)
VPS_SMB_PUBLIC_PORT=1445
VPS_SFTP_PORT=2222

# Service auth
VPS_API_TOKEN=replace-with-strong-token
VPS_ADMIN_USERNAME=admin
VPS_ADMIN_PASSWORD=replace-with-strong-admin-password
VPS_ADMIN_SESSION_SECONDS=43200

# SMB manager/runtime
VPS_SAMBA_MANAGE_ENABLED=true

# Cloud mount manager (rclone)
VPS_MOUNT_MANAGE_ENABLED=true
VPS_MOUNT_POLL_SECONDS=30

# SFTP access
VPS_SFTP_USERNAME=tmbackup
VPS_SFTP_PASSWORD=replace-with-strong-sftp-password
VPS_SFTP_UID=10000
VPS_SFTP_GID=10000
