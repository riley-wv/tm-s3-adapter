# /etc/samba/smb.conf additions
# Enable drop-in share files generated by the VPS dashboard:

include = /etc/samba/smb.conf.d/tm-adapter/_generated.conf

# The dashboard writes share files into:
# /etc/samba/smb.conf.d/tm-adapter/*.conf
# and composes a generated include:
# /etc/samba/smb.conf.d/tm-adapter/_generated.conf
# including:
# - _root.conf (root share for mounting sub-drives)
# - <disk-id>.conf per Time Machine drive
